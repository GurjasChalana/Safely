{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "server/dist",
    "rootDir": ".",
    "esModuleInterop": true
  },
  "include": ["server/**/*.ts", "src/shared/types.ts"],
  "exclude": ["dist", "node_modules"]
}
